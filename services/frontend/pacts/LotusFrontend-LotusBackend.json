{
  "consumer": {
    "name": "LotusFrontend"
  },
  "interactions": [
    {
      "description": "a request to create a journal",
      "providerStates": [
        {
          "name": "a user exists"
        }
      ],
      "request": {
        "body": {
          "journal_text": "Today was a great day!",
          "user_id": "a91b114d-b3de-4fe6-b162-039c9850c06b",
          "user_mood": "8"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.journal_text": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.user_id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.user_mood": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/v1/journals"
      },
      "response": {
        "body": {
          "journalId": "123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.journalId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to create an OAuth user",
      "providerStates": [
        {
          "name": "no user with this email exists"
        }
      ],
      "request": {
        "body": {
          "email": "newuser@example.com",
          "oauth_provider": "github"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.oauth_provider": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/v1/oauth/users"
      },
      "response": {
        "body": {
          "userId": "b91b114d-b3de-4fe6-b162-039c9850c06b"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.userId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to get feature flags for a role",
      "providerStates": [
        {
          "name": "feature flags exist"
        }
      ],
      "request": {
        "matchingRules": {
          "query": {
            "user_role": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "GET",
        "path": "/v1/feature-flags",
        "query": {
          "user_role": ["Consumer"]
        }
      },
      "response": {
        "body": {
          "flags": [
            {
              "isActive": true,
              "name": "dark_mode"
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.flags": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.flags[*].isActive": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.flags[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to get journals with pagination",
      "providerStates": [
        {
          "name": "a user has journal entries"
        }
      ],
      "request": {
        "matchingRules": {
          "query": {
            "limit": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "offset": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "user_id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "GET",
        "path": "/v1/journals",
        "query": {
          "limit": ["10"],
          "offset": ["0"],
          "user_id": ["a91b114d-b3de-4fe6-b162-039c9850c06b"]
        }
      },
      "response": {
        "body": {
          "hasMore": false,
          "journals": [
            {
              "createdAt": "2026-01-15T10:00:00Z",
              "journalId": "1",
              "journalText": "Today was a great day!",
              "userId": "a91b114d-b3de-4fe6-b162-039c9850c06b",
              "userMood": "8"
            }
          ],
          "totalCount": "5"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.hasMore": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.journals": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.journals[*].createdAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.journals[*].journalId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.journals[*].journalText": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.journals[*].userId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.journals[*].userMood": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.totalCount": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
