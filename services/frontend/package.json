{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:ci": "playwright test --reporter=github",
    "test:contract": "jest --testPathPatterns=\"__tests__/contract/.*\\.pact\\.test\\.ts$\" --testPathIgnorePatterns='[]' --testEnvironment=node --runInBand",
    "test:contract:publish": "npx pact-broker publish ./pacts --consumer-app-version=$(git rev-parse --short HEAD) --broker-base-url=http://localhost:9292 --broker-username=pact --broker-password=pact"
  },
  "packageManager": "npm@11.2.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react",
    "jsdom": "^26.0.0",
    "tar": "^7.5.0",
    "rimraf": "^5.0.0",
    "graphql": "^16.11.0"
  },
  "dependencies": {
    "@tailwindcss/typography": "github:tailwindcss/typography",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "lucide-react": "^0.503.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.9.2",
    "tailwind-merge": "^3.2.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@pact-foundation/pact": "^9.18.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.4",
    "tw-animate-css": "^1.2.8",
    "typescript": "^5"
  }
}
