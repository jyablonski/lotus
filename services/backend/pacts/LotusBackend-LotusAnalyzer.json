{
  "consumer": {
    "name": "LotusBackend"
  },
  "interactions": [
    {
      "description": "a request to trigger OpenAI topic extraction",
      "providerStates": [
        {
          "name": "a journal entry exists in the analyzer database"
        }
      ],
      "request": {
        "body": {
          "force_reanalyze": false
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.force_reanalyze": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/v1/journals/123/openai/topics"
      },
      "response": {
        "status": 204
      }
    },
    {
      "description": "a request to trigger sentiment analysis",
      "providerStates": [
        {
          "name": "a journal entry exists in the analyzer database"
        }
      ],
      "request": {
        "body": {
          "force_reanalyze": false
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.force_reanalyze": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "PUT",
        "path": "/v1/journals/123/sentiment"
      },
      "response": {
        "body": {
          "confidence": 0.85,
          "confidence_level": "high",
          "created_at": "2026-01-15T10:00:00Z",
          "id": 1,
          "is_reliable": true,
          "journal_id": 123,
          "ml_model_version": "v1.0.0",
          "sentiment": "positive"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.confidence": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.confidence_level": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.created_at": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.is_reliable": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.journal_id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.ml_model_version": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.sentiment": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-go": {
      "version": "2.4.2"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "mockserver": "1.2.16",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "LotusAnalyzer"
  }
}
