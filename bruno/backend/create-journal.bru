meta {
  name: Create Journal
  type: http
  seq: 1
}

post {
  url: {{backend_url}}/v1/journals
  body: json
  auth: none
}

body:json {
  {
    "userId": "{{user_id}}",
    "journalText": "Today was a productive day. I managed to finish the feature I was working on and felt accomplished.",
    "userMood": "8"
  }
}
