meta {
  name: Update Community Settings
  type: http
}

patch {
  url: {{backend_url}}/v1/users/{{user_id}}/community-settings
  body: json
  auth: inherit
}

body:json {
{
  "communityInsightsOptIn": false,
  "communityLocationOptIn": false,
  "communityCountryCode": "string",
  "communityRegionCode": "string"
}
}
